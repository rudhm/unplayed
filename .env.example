# Spotify API (REQUIRED for URI resolution and playlist management only)
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Last.fm API (REQUIRED for music discovery intelligence)
# Get your API key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# Spotify Export (OPTIONAL but recommended for play history filtering)
# Download your data at: https://www.spotify.com/account/privacy/
# Point to the directory containing StreamingHistory*.json files
SPOTIFY_EXPORT_PATH=/path/to/spotify/export/folder

# IFTTT Webhook (OPTIONAL - Alternative output when Spotify API is restricted)
# Get your webhook key at: https://ifttt.com/maker_webhooks/settings
# Setup: Create applet with "Webhooks → Spotify" integration
IFTTT_WEBHOOK_KEY=your_ifttt_webhook_key_here
